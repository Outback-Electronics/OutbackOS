// No polkit authentication agent runs in the Outback kiosk session, so the
// default interactive auth_admin prompt for pkexec can never be satisfied.
// Grant the specific, narrow set of actions the Outback apps invoke via
// pkexec directly, rather than leaving them silently hanging or falling
// back to a permissive sudoers rule.
polkit.addRule(function(action, subject) {
    if (action.id !== "org.freedesktop.policykit.exec") {
        return polkit.Result.NOT_HANDLED;
    }

    if (subject.user !== "outback") {
        return polkit.Result.NOT_HANDLED;
    }

    var allowedPrograms = [
        "/usr/bin/hostnamectl",
        "/usr/sbin/rfkill",
        "/usr/bin/apt-get",
        "/usr/bin/outback-toggle-autoupdates",
        "/usr/bin/outback-launch-calamares"
    ];

    if (allowedPrograms.indexOf(action.lookup("program")) !== -1) {
        return polkit.Result.YES;
    }

    return polkit.Result.NOT_HANDLED;
});

// NetworkManager is configured with auth-polkit=true, so nmcli's
// "device wifi connect" (used by the Settings app to add/activate
// connections) asks polkit for org.freedesktop.NetworkManager.* actions.
// With no agent present to answer an auth_admin prompt, those requests
// fail with "insufficient privileges". Grant them directly to the
// outback user, same as the pkexec actions above.
polkit.addRule(function(action, subject) {
    if (action.id.indexOf("org.freedesktop.NetworkManager.") !== 0) {
        return polkit.Result.NOT_HANDLED;
    }

    if (subject.user !== "outback") {
        return polkit.Result.NOT_HANDLED;
    }

    return polkit.Result.YES;
});

// The shell's Restart/Shut Down tiles run `systemctl reboot`/`poweroff`,
// which ask logind for org.freedesktop.login1.reboot / power-off (or the
// "-multiple-sessions" variant, e.g. while a session is still shutting
// down from a previous attempt). The implicit "allow_active" policy for
// those actions would normally cover this, but with no agent to answer
// even an auth_admin_keep prompt for the multiple-sessions variant, grant
// both directly to the outback user rather than have them hang silently.
polkit.addRule(function(action, subject) {
    var loginActions = [
        "org.freedesktop.login1.reboot",
        "org.freedesktop.login1.reboot-multiple-sessions",
        "org.freedesktop.login1.power-off",
        "org.freedesktop.login1.power-off-multiple-sessions"
    ];

    if (loginActions.indexOf(action.id) === -1) {
        return polkit.Result.NOT_HANDLED;
    }

    if (subject.user !== "outback") {
        return polkit.Result.NOT_HANDLED;
    }

    return polkit.Result.YES;
});
