<?xml version="1.0"?>
<labwc_config>

  <!--
    Outback OS ships each app's own window chrome via labwc's
    server-side decorations (title bar with iconify/maximize/close),
    since the Qt/QML apps don't draw their own. See outback-taskbar
    for the persistent taskbar that lists/switches/closes windows.
  -->

  <core>
    <decoration>server</decoration>
  </core>

  <keyboard>
    <default />
    <keybind key="Super_L">
      <action name="Execute" command="/usr/bin/outback-toggle-start-menu" />
    </keybind>
    <keybind key="Super_R">
      <action name="Execute" command="/usr/bin/outback-toggle-start-menu" />
    </keybind>
    <keybind key="W-l">
      <action name="Execute" command="/usr/bin/outback-lock" />
    </keybind>
    <keybind key="W-Left">
      <action name="SnapToEdge" direction="left" />
    </keybind>
    <keybind key="W-Right">
      <action name="SnapToEdge" direction="right" />
    </keybind>
    <keybind key="W-Up">
      <action name="SnapToEdge" direction="up" />
    </keybind>
    <keybind key="W-Down">
      <action name="SnapToEdge" direction="down" />
    </keybind>
  </keyboard>

  <mouse>
    <default />
  </mouse>

  <windowSwitcher show="true" preview="true" outlines="true">
    <fields>
      <field content="app_id" width="35%" />
      <field content="title" width="65%" />
    </fields>
  </windowSwitcher>

</labwc_config>
