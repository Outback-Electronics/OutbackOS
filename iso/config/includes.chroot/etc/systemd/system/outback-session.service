[Unit]
Description=Outback OS graphical session
After=systemd-user-sessions.service systemd-logind.service
Wants=systemd-user-sessions.service

[Service]
User=outback
Group=outback
PAMName=login
TTYPath=/dev/tty1
StandardInput=tty
ExecStart=/usr/local/bin/outback-session
Restart=on-failure

[Install]
WantedBy=graphical.target
